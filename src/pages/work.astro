---
import BaseLayout from '../layouts/BaseLayout.astro';

const work = [
  {
    title: 'Forecasting and decision-support platforms',
    text: 'Building systems that move from raw operational data through Spark-class distributed processing, Iceberg/Nessie-style lakehouse architecture, normalized analytical layers, model execution, evaluation, APIs, and dashboards. Current work focuses on forecasting and decision-support platforms for demand planning, inventory health, pricing, and operational analytics, with reproducible pipelines and serving layers designed to make model outputs usable in production workflows.',
  },
  {
    title: 'AI-assisted development orchestration',
    text: 'Designing autonomous software development systems that route work across AI coding backends, preserve scope through structured task contracts, verify changes deterministically, and handle failure through explicit retry and escalation paths. A core architectural focus is the idea that dependable AI-assisted development emerges from contracts, verification, evidence, bounded execution, and governed progression — not prompt quality alone. Current work includes context contracts, backend capability harnesses, execution evidence systems, reconciliation workflows, and governed multi-backend orchestration across Codex CLI, Claude Code CLI, Gemini CLI, Aider, PI, and OpenCode.',
  },
  {
    title: 'Data platform modernization',
    text: 'Converting fragmented or legacy data workflows into scalable, maintainable platforms using cloud-native services, columnar data formats, reproducible pipelines, and production serving layers.',
  },
  {
    title: 'Document intelligence systems',
    text: 'Developing document intelligence systems that combine LLMs, embeddings, vector stores, and structured search to support code generation, research agents, operational assistants, and document-heavy business workflows.',
  },
];
---

<BaseLayout
  title="Work | Mike Fox"
  description="Current work themes for Mike Fox: forecasting systems, AI development orchestration, data platforms, and document intelligence applications."
>
        <section class="page-title">
          <p class="eyebrow">Current work</p>
          <h1>Things I am working on.</h1>
        </section>

        <section class="grid two">
          {work.map((item) => (
            <article class="card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </section>
</BaseLayout>
