---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = (await getCollection('articles')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Articles | Mike Fox"
  description="Articles and notes by Mike Fox on dependable AI-assisted development, architecture, model routing, task contracts, and production systems."
>
        <section class="page-title">
          <p class="eyebrow">Articles</p>
          <h1>Articles</h1>
          <p>Notes on dependable AI-assisted development and production architecture.</p>
        </section>

        <section class="stack">
          {articles.map((article) => (
            <article class="card article-card">
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <a href={`/articles/${article.data.slug}/`}>Read article</a>
            </article>
          ))}
        </section>
</BaseLayout>
