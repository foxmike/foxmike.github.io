---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const articles = (await getCollection('articles')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Articles | Mike Fox</title>
    <meta name="description" content="Articles and notes by Mike Fox on dependable AI-assisted development, architecture, model routing, task contracts, and production systems." />
  </head>
  <body>
    <div class="site">
      <nav class="nav">
        <a class="brand" href="/">Mike Fox</a>
        <div class="nav-links">
          <a href="/capabilities/">Capabilities</a>
          <a href="/work/">Work</a>
          <a href="/articles/">Articles</a>
          <a href="/about/">About</a>
          <a href="https://github.com/foxmike">GitHub</a>
        </div>
      </nav>

      <main class="main">
        <section class="page-title">
          <p class="eyebrow">Articles</p>
          <h1>Articles</h1>
          <p>Notes on dependable AI-assisted development and production architecture.</p>
        </section>

        <section class="stack">
          {articles.map((article) => (
            <article class="card article-card">
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <a href={`/articles/${article.data.slug}/`}>Read article</a>
            </article>
          ))}
        </section>
      </main>

      <footer class="footer">
        <span>© Mike Fox</span>
        <span><a href="mailto:foxmike@gmail.com">foxmike@gmail.com</a></span>
      </footer>
    </div>
  </body>
</html>
