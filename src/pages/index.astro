---
import BaseLayout from '../layouts/BaseLayout.astro';

const capabilities = [
  {
    title: 'Forecasting and Decision Platforms',
    text: 'Time-series forecasting, analytics, and decision-support systems built on high-performance data foundations with modeling, APIs, dashboards, and production serving layers.',
  },
  {
    title: 'AI Development Orchestration',
    text: 'Supervisor-driven systems that coordinate planning, execution, review, verification, retry, and structured failure handling across multiple AI coding backends.',
  },
  {
    title: 'Data Platforms and Lakehouse Architecture',
    text: 'Extraction, ingestion, normalization, transformation, analytics pipelines, Iceberg/Parquet data layers, warehouses, and production-grade serving architecture.',
  },
];

const aiArchitectureCards = [
  {
    title: 'Architecture before acceleration',
    text: 'AI can speed implementation, but the system still needs clear boundaries, data contracts, service responsibilities, and a design that can survive production change.',
  },
  {
    title: 'Verification over confidence',
    text: 'Generated output is treated as provisional until tests, reviews, data checks, and acceptance gates prove that it behaves correctly in the real system.',
  },
  {
    title: 'Production systems, not demos',
    text: 'Fast prototypes are useful, but durable software needs scalability, observability, maintainability, operational fit, and disciplined delivery judgment.',
  },
];

const focusAreas = [
  'Forecasting and analytics platforms',
  'Autonomous development orchestration systems',
  'Multi-backend AI and agentic workflow systems',
  'Document intelligence systems',
  'Operational dashboards and decision-support tools',
  'Legacy platform modernization',
  'Custom backend and API platforms',
  'Production ML and model-serving systems',
  'Supply chain, healthcare, energy, and manufacturing analytics',
];
---

<BaseLayout
  title="Mike Fox | Software Architecture, Data Platforms, AI-Enabled Systems"
  description="Mike Fox - senior software architect focused on data platforms, forecasting systems, AI-enabled applications, autonomous development orchestration, and production software architecture."
>
        <section class="hero">
          <p class="eyebrow">Senior Architect · Data Platforms · AI-Enabled Systems</p>
          <h1>AI-accelerated delivery with production-grade architecture.</h1>
          <p class="lead">
            I use AI to increase development speed while preserving architectural control, data correctness, maintainable boundaries, verification, scalability, and production readiness.
          </p>
          <div class="actions">
            <a class="button primary" href="/capabilities/">View capabilities</a>
            <a class="button" href="/work/">Current work</a>
            <a class="button" href="mailto:foxmike@gmail.com">Contact</a>
          </div>
        </section>

        <section class="section">
          <div class="section-header">
            <h2>AI speed without architectural debt.</h2>
            <p>
              AI can produce code and demos quickly. Production systems still require architecture, verification, maintainable boundaries, data correctness, and operational discipline so faster delivery does not become slower recovery.
            </p>
          </div>

          <div class="grid three">
            {aiArchitectureCards.map((item) => (
              <article class="card">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="section">
          <div class="section-header">
            <h2>What I build</h2>
            <p>
              Systems that connect raw operational data, analytics pipelines, models, and user-facing applications into durable production architectures.
            </p>
          </div>

          <div class="grid three">
            {capabilities.map((item) => (
              <article class="card">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="section split">
          <div>
            <p class="eyebrow">Operating focus</p>
            <h2>Architecture with execution discipline.</h2>
          </div>
          <div class="callout">
            <p>
              The work is not only choosing tools. It is decomposing complex business problems into systems that can be built, tested, operated, extended, and trusted — with minimal technical debt and clear boundaries between data, models, services, and users.
            </p>
          </div>
        </section>

        <section class="section">
          <div class="section-header">
            <h2>Core capability areas</h2>
            <p>
              A practical mix of data architecture, backend engineering, AI-enabled workflows, forecasting systems, modernization, and production delivery.
            </p>
          </div>

          <div class="pill-list">
            {focusAreas.map((area) => <span class="pill">{area}</span>)}
          </div>
        </section>

        <section class="section">
          <div class="section-header">
            <h2>Current themes</h2>
            <p>
              Independent work and advisory focus are centered on forecasting and decision-support systems, autonomous software development orchestration, multi-model AI systems, and practical AI adoption for production software organizations.
            </p>
          </div>

          <div class="grid two">
            <article class="card">
              <h3>Forecasting and decision systems</h3>
              <p>
                Platforms for demand planning, market modeling, inventory health, pricing, operational analytics, and energy-market analysis using reproducible data pipelines, model evaluation, and decision-oriented dashboards.
              </p>
            </article>

            <article class="card">
              <h3>Autonomous development orchestration</h3>
              <p>
                Systems that coordinate AI coding backends through structured task contracts, deterministic verification, reviewer/verifier loops, sandboxed execution, git automation, and tiered retry strategies.
              </p>
            </article>
          </div>
        </section>
</BaseLayout>
